<% if @user.teams.blank? %>
  <div class="portal-welcome">
    <h3>Welcome, <%= @user.name %></h3>

    <div class="portal-instructions">
      Before you begin, create your team!
    </div>

    <%= render partial: 'teams/new' %>
  </div>
<% else %>
  <div class="portal-welcome">
    Hello, <%= @user.name %>.

    <h2><%= @user.team %></h2>
  </div>
<% end %>