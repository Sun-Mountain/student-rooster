<%= render TurboModalComponent.new(title: "Invite Members to #{@team.name}") do %>
  <% form_for @membership, url: new_team_membership_path, html: { method: :put } do |f| %>
    <div class="modal__form-wrapper">
      <div class="field">
        <%= f.label :email %>
        <div class="input-wrapper">
          <%= f.text_field :email, autofocus: true, autocomplete: "email", class: "text-input" %>
        </div>
      </div>
      <div class="form-btn__container">
        <%= f.submit "Update", class: "modal-btn modal-btn__submit" %>
        <%= button_tag data: { action: "turbo-modal#hideModal" }, type: "button", class: "modal-btn__cancel" do %>
          Cancel
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>