<div>
  <div>
    <div>
      <h2><%= @lesson.name %> Roster</h2>
      <h3><%= @roster.dates %></h3>
    </div>

    <div class="form-wrapper">
      <h3>Create a New Lesson</h3>
      <%= form_with model: [ @user, @team, @team.lessons.build ] do |form| %>
        <div class="field">
          <%= form.label :name %><br>
          <%= form.text_field :name, class: "field-text" %>
        </div>

        <div class="field">
          <%= form.submit "Add Lesson", class: "form-button"  %>
        </div>
      <% end %>
    </div>
  </div>
  <div>
    <%= link_to "Back", :back %>
  </div>
</div>
