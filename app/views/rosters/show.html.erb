<div>
  <div>
    <div>
      <h2><%= @lesson.name %> Roster</h2>
      <h3><%= @roster.dates %></h3>
    </div>

    <div class="form-wrapper">
      <h3>Add a New Student to Roster</h3>
      <%= form_with model: [ @user, @team, @lesson, @roster, @roster.students.build ] do |form| %>
        <div class="field">
          <%= form.label :first_name %><br>
          <%= form.text_field :first_name, class: "field-text" %>
        </div>

        <div class="field">
          <%= form.label :last_name %><br>
          <%= form.text_field :last_name, class: "field-text" %>
        </div>

        <div class="field">
          <%= form.label :email %><br>
          <%= form.text_field :email, class: "field-text" %>
        </div>

        <div class="field">
          <%= form.label :phone %><br>
          <%= form.text_field :phone, class: "field-text" %>
        </div>

        <div class="field">
          <%= form.submit "Add New Student", class: "form-button"  %>
        </div>
      <% end %>
    </div>

    <div class="roster-student-list">
      <% if @roster.no_students? %>
        No students
      <% else%>
        Yay students
      <% end %>
    </div>
  </div>
  <div>
    <%= link_to "Back", :back %>
  </div>
</div>
