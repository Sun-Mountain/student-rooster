<%= render 'teams/header' %>
<%= render 'lessons/header' %>

<div class="page-container">
  <div class="form-container">

    <div class="form-heading-wrapper">
      <h2>Create A New Class</h2>
    </div>

    <div class="form-wrapper">
      <%= form_for @roster, url: team_lesson_rosters_path, html: { method: :post } do |f| %>
        <div class="field">
          <%= f.label :name %>
          <div class="input-wrapper">
            <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "text-input" %>
          </div>
        </div>
        <div class="field">
          <%= f.label :start_date %>
          <%= f.date_field :start_date, min: 0.days.ago, class: "text-input" %>
        </div>
        <div class="field">
          <%= f.label :end_date %>
          <%= f.date_field :end_date, min: 0.days.ago, class: "text-input" %>
        </div>
        <div class="form-btn-wrapper">
          <%= f.submit "Add Class", class: "form-btn" %>
        </div>
      <% end %>
    </div>